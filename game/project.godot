config_version=5

[application]

config/name="Tower Drop"
config/description="Endless tower faller — design doc: ../../docs/game-design.md (open repo root)."
config/version="0.0.1"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")

[autoload]

